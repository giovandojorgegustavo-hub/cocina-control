# Base URL of the backend API.
#
# Development: leave empty. Vite's dev server proxies /api to the backend
# (target set in vite.config.ts, default http://127.0.0.1:8000). Requests
# stay same-origin so no CORS is needed on the backend.
#
# Production: set to the absolute URL of the backend when the build runs
# against a different origin. When Caddy serves both frontend and backend
# on the same origin (the intended v0.2 topology), keep this empty too.
VITE_API_URL=

# Optional: override the dev proxy target (only read by Vite in dev).
# Uncomment to point at a backend on a different host or port.
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
