# Base URL of the backend API.
#
# Development: leave empty. Vite's dev server proxies /api to the backend
# (target set in vite.config.ts, default http://127.0.0.1:8000). Requests
# stay same-origin so no CORS is needed on the backend.
#
# Production: set to the absolute URL of the backend when the build runs
# against a different origin. When Caddy serves both frontend and backend
# on the same origin (the intended v0.2 topology), keep this empty too.
VITE_API_URL=

# Optional: override the dev proxy target. Read by Vite as a *Node-side*
# environment variable at config load time (NOT injected into the browser
# bundle). To use it: prefix the dev command inline
#   VITE_DEV_PROXY_TARGET=http://127.0.0.1:9000 npm run dev
# or export it in the shell before `npm run dev`. Setting it here in .env
# also works because Vite loads .env before evaluating vite.config.ts.
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# Base path for the frontend app.
#
# Development: leave as '/' (default). The Vite dev server serves the app
# from the root and the /api proxy works as-is.
#
# Production (bonabowl.com/interno): set to '/interno/' so Vite prefixes all
# asset URLs and the router basename is configured correctly. The value MUST
# end with a trailing slash — vite.config.ts adds it defensively if missing.
#   VITE_BASE_PATH=/interno/ npm run build
VITE_BASE_PATH=/
