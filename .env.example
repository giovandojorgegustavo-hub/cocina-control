# Cocina Control - environment variables
# Copy this file to .env and fill in the values for local development.

COCINA_APP_ENV=dev
COCINA_LOG_LEVEL=INFO

COCINA_DATABASE_URL=postgresql+psycopg://usuario:pass@localhost:5432/cocina_control

# JWT signing secret -- minimum 32 characters, recommended 64.
# Generate a secure value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
COCINA_JWT_SECRET=

# Business timezone -- used for all calendar-day calculations:
# operator correction windows, dashboard "today" filters, and from/to date
# range conversion to UTC.  Must be a valid IANA timezone name.
# The kitchen operates in Peru -> America/Lima (UTC-5, no DST).
# Change this env var if the business relocates or opens a second kitchen;
# no code change or database migration is required.
COCINA_BUSINESS_TIMEZONE=America/Lima
