# Cocina Control - environment variables
# Copy this file to .env and fill in the values for local development.

COCINA_APP_ENV=dev
COCINA_LOG_LEVEL=INFO

COCINA_DATABASE_URL=postgresql+psycopg://usuario:pass@localhost:5432/cocina_control

# JWT signing secret — minimum 32 characters, recommended 64.
# Generate a secure value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
COCINA_JWT_SECRET=
